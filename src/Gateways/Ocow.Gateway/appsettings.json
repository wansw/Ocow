{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "Observability": {
    "ServiceName": "Ocow.Gateway",
    "ServiceVersion": "1.0.0",
    "OtlpEndpoint": "http://localhost:4317",
    "EnableRequestTrace": true,
    "EnableTracing": false,
    "EnableMetrics": false,
    "Logging": {
      "MinimumLevel": "Information",
      "EnableConsole": true,
      "EnableFile": false,
      "EnableOpenTelemetry": false,
      "EnableRequestLogging": true,
      "FilePath": "logs/Ocow.Gateway-.json",
      "RollingInterval": "Day",
      "RetainedFileCountLimit": 30
    }
  },
  "Redis": {
    "Configuration": "localhost:6379,abortConnect=false",
    "KeyPrefix": "ocow",
    "DefaultDatabase": 0
  },
  "Cache": {
    "KeyPrefix": "ocow",
    "DefaultExpireSeconds": 300
  },
  "Jwt": {
    "Issuer": "Ocow.Identity",
    "Audience": "Ocow.Clients",
    "Secret": "OcowIdentityJwtSecret@2026-ChangeInProduction"
  },
  "InternalAuth": {
    "Issuer": "Ocow.InternalAuth",
    "Audience": "Ocow.InternalServices",
    "Secret": "PleaseChangeThisInternalServiceJwtSecret",
    "ServiceName": "Ocow.Gateway",
    "TokenExpireMinutes": 5
  },
  "GatewayForwardedJwt": {
    "Enabled": false,
    "Issuer": "Ocow.Gateway",
    "Audience": "Ocow.Microservices",
    "Secret": "PleaseChangeThisGatewayForwardedJwtSecret",
    "TokenExpireMinutes": 5,
    "GatewayName": "Ocow.Gateway"
  },
  "GatewaySecurity": {
    "Enabled": true,
    "DenyUnmatchedRoutes": true,
    "TrustForwardedForHeader": false,
    "IpWhitelist": [],
    "IpBlacklist": [],
    "RateLimit": {
      "Enabled": true,
      "PermitLimit": 120,
      "WindowSeconds": 60
    },
    "Routes": [
      {
        "PathPrefix": "/health",
        "AllowAnonymous": true
      },
      {
        "PathPrefix": "/api/auth/me",
        "AuthenticationScheme": "CustomerJwt",
        "AuthorizationPolicy": "CustomerOnly",
        "ForwardUserIdentity": true
      },
      {
        "PathPrefix": "/api/auth",
        "AllowAnonymous": true
      },
      {
        "PathPrefix": "/api/admin/auth",
        "AllowAnonymous": true
      },
      {
        "PathPrefix": "/hangfire",
        "AllowAnonymous": true
      },
      {
        "PathPrefix": "/api/orders",
        "AuthenticationScheme": "CustomerJwt",
        "AuthorizationPolicy": "CustomerOnly",
        "ForwardUserIdentity": true
      },
      {
        "PathPrefix": "/api/admin",
        "AuthenticationScheme": "AdminJwt",
        "AuthorizationPolicy": "AdminOnly",
        "ForwardUserIdentity": true
      },
      {
        "PathPrefix": "/internal",
        "AuthenticationScheme": "ServiceJwt",
        "AuthorizationPolicy": "InternalOnly"
      }
    ]
  },
  "AllowedHosts": "*"
}
