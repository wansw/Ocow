{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "Observability": {
    "ServiceName": "Ocow.Gateway"
  },
  "Redis": {
    "Configuration": "localhost:6379,abortConnect=false",
    "KeyPrefix": "ocow",
    "DefaultExpireSeconds": 300,
    "DefaultDatabase": 0
  },
  "AllowedHosts": "*"
}
