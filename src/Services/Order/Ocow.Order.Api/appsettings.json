{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "Observability": {
    "ServiceName": "Ocow.Order.Api",
    "ServiceVersion": "1.0.0",
    "OtlpEndpoint": "http://localhost:4317",
    "EnableRequestTrace": true,
    "EnableTracing": false,
    "EnableMetrics": false,
    "Logging": {
      "MinimumLevel": "Information",
      "EnableConsole": true,
      "EnableFile": false,
      "EnableOpenTelemetry": false,
      "EnableRequestLogging": true,
      "FilePath": "logs/Ocow.Order.Api-.json",
      "RollingInterval": "Day",
      "RetainedFileCountLimit": 30
    }
  },
  "OpenApi": {
    "ServiceName": "Ocow.Order.Api",
    "Version": "v1",
    "Description": "Ocow 订单服务接口文档"
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=ocow_order;Username=postgres;Password=postgres123"
  },
  "Database": {
    "Provider": "PostgreSql",
    "ConnectionString": "Host=localhost;Port=5432;Database=ocow_order;Username=postgres;Password=postgres123"
  },
  "EventBus": {
    "DefaultGroupName": "ocow.order-service",
    "FailedRetryCount": 5,
    "FailedRetryIntervalSeconds": 60,
    "Storage": {
      "Provider": "PostgreSql",
      "ConnectionStringName": "Default"
    },
    "RabbitMq": {
      "HostName": "localhost",
      "Port": 5672,
      "UserName": "admin",
      "Password": "admin123",
      "VirtualHost": "/",
      "ExchangeName": "ocow.events"
    },
    "Dashboard": {
      "Enabled": true,
      "PathMatch": "/cap",
      "AllowAnonymousExplicit": false,
      "AuthorizationPolicy": "AdminOnly"
    }
  },
  "Redis": {
    "Configuration": "localhost:6379,abortConnect=false",
    "KeyPrefix": "ocow",
    "DefaultDatabase": 0
  },
  "Cache": {
    "KeyPrefix": "ocow",
    "DefaultExpireSeconds": 300
  },
  "Jwt": {
    "Issuer": "Ocow.Identity",
    "Audience": "Ocow.Clients",
    "Secret": "OcowIdentityJwtSecret@2026-ChangeInProduction"
  },
  "InternalAuth": {
    "Issuer": "Ocow.InternalAuth",
    "Audience": "Ocow.InternalServices",
    "Secret": "PleaseChangeThisInternalServiceJwtSecret"
  },
  "HmacSignature": {
    "Secret": "PleaseChangeThisInternalHmacSecret",
    "TimestampToleranceSeconds": 300
  },
  "AllowedHosts": "*"
}
