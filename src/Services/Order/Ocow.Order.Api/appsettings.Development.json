{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Observability": {
    "ServiceVersion": "1.0.0-dev",
    "EnableRequestTrace": true,
    "EnableTracing": false,
    "EnableMetrics": false,
    "Logging": {
      "MinimumLevel": "Debug",
      "EnableConsole": true,
      "EnableFile": false,
      "EnableOpenTelemetry": false,
      "EnableRequestLogging": true,
      "FilePath": "logs/Ocow.Order.Api-dev-.json"
    }
  },
  "EventBus": {
    "RabbitMq": {
      "HostName": "localhost",
      "Port": 5672,
      "UserName": "admin",
      "Password": "admin123",
      "VirtualHost": "/"
    },
    "Dashboard": {
      "Enabled": true,
      "AllowAnonymousExplicit": true,
      "AuthorizationPolicy": null
    }
  },
  "GatewayForwardedJwt": {
    "Enabled": true,
    "AllowDirectIdentityJwt": true
  }
}
