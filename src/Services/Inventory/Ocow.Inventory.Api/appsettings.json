{
  "Observability": {
    "ServiceName": "Ocow.Inventory.Api",
    "ServiceVersion": "1.0.0",
    "OtlpEndpoint": "http://localhost:4317",
    "EnableRequestTrace": true,
    "EnableTracing": false,
    "EnableMetrics": false,
    "Logging": {
      "MinimumLevel": "Information",
      "EnableConsole": true,
      "EnableFile": false,
      "EnableOpenTelemetry": false,
      "EnableRequestLogging": true,
      "FilePath": "logs/Ocow.Inventory.Api-.json",
      "RollingInterval": "Day",
      "RetainedFileCountLimit": 30
    }
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=ocow_inventory;Username=postgres;Password=postgres123"
  },
  "Database": {
    "Provider": "PostgreSql",
    "ConnectionString": "Host=localhost;Port=5432;Database=ocow_inventory;Username=postgres;Password=postgres123"
  },
  "EventBus": {
    "DefaultGroupName": "ocow.inventory-service",
    "FailedRetryCount": 5,
    "FailedRetryIntervalSeconds": 60,
    "Storage": {
      "Provider": "PostgreSql",
      "ConnectionStringName": "Default"
    },
    "RabbitMq": {
      "HostName": "localhost",
      "Port": 5672,
      "UserName": "admin",
      "Password": "admin123",
      "VirtualHost": "/",
      "ExchangeName": "ocow.events"
    },
    "Dashboard": {
      "Enabled": true,
      "PathMatch": "/cap",
      "AllowAnonymousExplicit": true,
      "AuthorizationPolicy": null
    }
  },
  "HealthChecks": {
    "PostgreSql": {
      "Enabled": true,
      "ConnectionString": "Host=localhost;Port=5432;Database=ocow_inventory;Username=postgres;Password=postgres123"
    }
  },
  "AllowedHosts": "*"
}
