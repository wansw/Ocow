{
  "Observability": {
    "ServiceVersion": "1.0.0",
    "OtlpEndpoint": "http://otel-collector:4317",
    "Logging": {
      "EnableConsole": false,
      "EnableOpenTelemetry": true
    }
  },
  "EventBus": {
    "DefaultGroupName": "ocow.inventory-service",
    "RabbitMq": {
      "HostName": "rabbitmq",
      "Port": 5672,
      "UserName": "ocow_inventory_service",
      "Password": "PleaseChangeThisRabbitMqPassword",
      "VirtualHost": "/",
      "ExchangeName": "ocow.events"
    },
    "Dashboard": {
      "Enabled": true,
      "PathMatch": "/cap",
      "AllowAnonymousExplicit": false,
      "AuthorizationPolicy": "AdminOnly"
    }
  }
}
