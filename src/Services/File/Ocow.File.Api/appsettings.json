{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "Observability": {
    "ServiceName": "Ocow.File.Api",
    "ServiceVersion": "1.0.0",
    "OtlpEndpoint": "http://localhost:4317",
    "EnableRequestTrace": true,
    "EnableTracing": false,
    "EnableMetrics": false,
    "Logging": {
      "MinimumLevel": "Information",
      "EnableConsole": true,
      "EnableFile": false,
      "EnableOpenTelemetry": false,
      "EnableRequestLogging": true,
      "FilePath": "logs/Ocow.File.Api-.json",
      "RollingInterval": "Day",
      "RetainedFileCountLimit": 30
    }
  },
  "OpenApi": {
    "ServiceName": "Ocow.File.Api",
    "Version": "v1",
    "Description": "Ocow 文件服务接口文档"
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=ocow_file;Username=postgres;Password=postgres123"
  },
  "Database": {
    "Provider": "PostgreSql",
    "ConnectionString": "Host=localhost;Port=5432;Database=ocow_file;Username=postgres;Password=postgres123"
  },
  "FileUpload": {
    "MaxTxtBytes": 2097152,
    "MaxExcelBytes": 20971520,
    "MaxImageBytes": 10485760,
    "AllowedExtensions": [ ".txt", ".xls", ".xlsx", ".jpg", ".jpeg", ".png", ".webp" ]
  },
  "FileStorage": {
    "StorageType": "Local",
    "LocalRootPath": ".appdata/files",
    "CosBucketName": "",
    "CosRegion": "ap-guangzhou",
    "CosSecretId": "",
    "CosSecretKey": "",
    "CosKeyPrefix": "uploads",
    "CosUseHttps": true,
    "CosCredentialDurationSeconds": 600,
    "DownloadTokenExpireSeconds": 300,
    "DownloadTokenSecret": "PleaseChangeThisFileDownloadTokenSecret"
  },
  "Redis": {
    "Configuration": "localhost:6379,abortConnect=false",
    "KeyPrefix": "ocow",
    "DefaultDatabase": 0
  },
  "Cache": {
    "KeyPrefix": "ocow",
    "DefaultExpireSeconds": 300
  },
  "Jwt": {
    "Issuer": "Ocow.Identity",
    "Audience": "Ocow.Clients",
    "Secret": "OcowIdentityJwtSecret@2026-ChangeInProduction"
  },
  "GatewayForwardedJwt": {
    "Enabled": true,
    "AllowDirectIdentityJwt": false,
    "Issuer": "Ocow.Gateway",
    "Audience": "Ocow.Microservices",
    "Secret": "PleaseChangeThisGatewayForwardedJwtSecret",
    "TokenExpireMinutes": 5,
    "GatewayName": "Ocow.Gateway"
  },
  "InternalAuth": {
    "Issuer": "Ocow.InternalAuth",
    "Audience": "Ocow.InternalServices",
    "Secret": "PleaseChangeThisInternalServiceJwtSecret"
  },
  "HmacSignature": {
    "Secret": "PleaseChangeThisInternalHmacSecret",
    "TimestampToleranceSeconds": 300
  },
  "AllowedHosts": "*"
}
