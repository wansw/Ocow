{
  "Observability": {
    "ServiceName": "Ocow.File.Api",
    "Logging": {
      "EnableFile": true,
      "FilePath": "logs/Ocow.File.Api-.json"
    }
  },
  "FileStorage": {
    "StorageType": "Local",
    "LocalRootPath": "/app/.appdata/files",
    "CosBucketName": "",
    "CosRegion": "ap-guangzhou",
    "CosSecretId": "",
    "CosSecretKey": "",
    "CosKeyPrefix": "uploads",
    "CosUseHttps": true,
    "CosCredentialDurationSeconds": 600,
    "DownloadTokenSecret": "PleaseChangeThisFileDownloadTokenSecretInProduction"
  },
  "GatewayForwardedJwt": {
    "Secret": "PleaseChangeThisGatewayForwardedJwtSecretInProduction"
  },
  "InternalAuth": {
    "Secret": "PleaseChangeThisInternalServiceJwtSecretInProduction"
  },
  "HmacSignature": {
    "Secret": "PleaseChangeThisInternalHmacSecretInProduction"
  }
}
