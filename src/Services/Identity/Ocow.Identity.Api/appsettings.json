{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "Observability": {
    "ServiceName": "Ocow.Identity.Api",
    "ServiceVersion": "1.0.0",
    "OtlpEndpoint": "http://localhost:4317",
    "EnableRequestTrace": true, //日志
    "EnableTracing": false,     //追踪
    "EnableMetrics": false,     //指标
    "Logging": {
      "MinimumLevel": "Information",
      "EnableConsole": true,
      "EnableFile": false,
      "EnableOpenTelemetry": false,
      "EnableRequestLogging": true,
      "FilePath": "logs/Ocow.Identity.Api-.json",
      "RollingInterval": "Day",
      "RetainedFileCountLimit": 30
    }
  },
  "OpenApi": {
    "ServiceName": "Ocow.Identity.Api",
    "Version": "v1",
    "Description": "Ocow 身份认证与权限服务接口文档"
  },
  "Database": {
    "Provider": "PostgreSql",
    "ConnectionString": "Host=localhost;Port=5432;Database=ocow_identity;Username=postgres;Password=postgres123"
  },
  "Redis": {
    "Configuration": "localhost:6379",
    "KeyPrefix": "ocow",
    "DefaultDatabase": 0
  },
  "Cache": {
    "KeyPrefix": "ocow",
    "DefaultExpireSeconds": 300
  },
  "Jwt": {
    "Issuer": "Ocow.Identity",
    "Audience": "Ocow.Clients",
    "Secret": "OcowIdentityJwtSecret@2026-ChangeInProduction",
    "AccessTokenMinutes": 120,
    "RefreshTokenDays": 7
  },
  "GatewayForwardedJwt": {
    "Enabled": true,
    "AllowDirectIdentityJwt": false,
    "Issuer": "Ocow.Gateway",
    "Audience": "Ocow.Microservices",
    "Secret": "PleaseChangeThisGatewayForwardedJwtSecret",
    "TokenExpireMinutes": 5,
    "GatewayName": "Ocow.Gateway"
  },
  "InternalAuth": {
    "Issuer": "Ocow.InternalAuth",
    "Audience": "Ocow.InternalServices",
    "Secret": "PleaseChangeThisInternalServiceJwtSecret"
  },
  "HmacSignature": {
    "Secret": "PleaseChangeThisInternalHmacSecret",
    "TimestampToleranceSeconds": 300
  },
  "AllowedHosts": "*"
}
