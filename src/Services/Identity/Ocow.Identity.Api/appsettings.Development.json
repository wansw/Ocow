{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Information"
      }
    }
  },
  "Observability": {
    "ServiceVersion": "1.0.0-dev",
    "EnableRequestTrace": true,
    "EnableTracing": false,
    "EnableMetrics": false,
    "Logging": {
      "MinimumLevel": "Debug",
      "EnableConsole": true,
      "EnableFile": false,
      "EnableOpenTelemetry": false,
      "EnableRequestLogging": true,
      "FilePath": "logs/Ocow.Identity.Api-dev-.json"
    }
  },
  "Database": {
    "ConnectionString": "Host=localhost;Port=5432;Database=ocow_identity_dev;Username=postgres;Password=postgres123"
  },
  "Redis": {
    "Configuration": "localhost:6379",
    "DefaultDatabase": 0
  },
  "GatewayForwardedJwt": {
    "Enabled": true,
    "AllowDirectIdentityJwt": true
  }
}
