{
  "Observability": {
    "EnableTracing": true,
    "EnableMetrics": true,
    "Logging": {
      "EnableFile": true,
      "EnableOpenTelemetry": true
    }
  },
  "Database": {
    "Provider": "PostgreSql",
    "ConnectionString": "Host=postgres;Port=5432;Database=ocow_jobs;Username=postgres;Password=PleaseChangeThisPassword"
  },
  "BackgroundJobs": {
    "DashboardPath": "/hangfire",
    "DashboardTitle": "Ocow Background Jobs",
    "DashboardPermissionCode": "scheduler.trigger",
    "SchemaName": "hangfire"
  },
  "Redis": {
    "Configuration": "redis:6379,abortConnect=false",
    "KeyPrefix": "ocow",
    "DefaultDatabase": 0
  },
  "Jwt": {
    "Issuer": "Ocow.Identity",
    "Audience": "Ocow.Clients",
    "Secret": "PleaseChangeThisJwtSecretInProduction"
  },
  "InternalAuth": {
    "Issuer": "Ocow.InternalAuth",
    "Audience": "Ocow.InternalServices",
    "Secret": "PleaseChangeThisInternalServiceJwtSecretInProduction",
    "ServiceName": "Ocow.Jobs",
    "TokenExpireMinutes": 10
  },
  "HmacSignature": {
    "Secret": "PleaseChangeThisInternalHmacSecretInProduction",
    "TimestampToleranceSeconds": 300
  }
}
