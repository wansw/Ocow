{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "Observability": {
    "ServiceName": "Ocow.Jobs",
    "ServiceVersion": "1.0.0",
    "OtlpEndpoint": "http://localhost:4317",
    "EnableRequestTrace": true,
    "EnableTracing": false,
    "EnableMetrics": false,
    "Logging": {
      "MinimumLevel": "Information",
      "EnableConsole": true,
      "EnableFile": false,
      "EnableOpenTelemetry": false,
      "EnableRequestLogging": true,
      "FilePath": "logs/Ocow.Jobs-.json",
      "RollingInterval": "Day",
      "RetainedFileCountLimit": 30
    }
  },
  "OpenApi": {
    "ServiceName": "Ocow.Jobs",
    "Version": "v1",
    "Description": "Ocow 后台任务服务接口文档。"
  },
  "Database": {
    "Provider": "PostgreSql",
    "ConnectionString": "Host=localhost;Port=5432;Database=ocow_jobs;Username=postgres;Password=postgres123"
  },
  "BackgroundJobs": {
    "DashboardPath": "/hangfire",
    "DashboardTitle": "Ocow Background Jobs",
    "DashboardPermissionCode": "scheduler.trigger",
    "SchemaName": "hangfire"
  },
  "ServiceEndpoints": {
    "Services": {
      "ocow-order-api": "https://localhost:7101"
    }
  },
  "Redis": {
    "Configuration": "localhost:6379,abortConnect=false",
    "KeyPrefix": "ocow",
    "DefaultDatabase": 0
  },
  "Jwt": {
    "Issuer": "Ocow.Identity",
    "Audience": "Ocow.Clients",
    "Secret": "OcowIdentityJwtSecret@2026-ChangeInProduction"    //这个不要写在配置
  },
  "GatewayForwardedJwt": {
    "Enabled": true,
    "AllowDirectIdentityJwt": false,
    "Issuer": "Ocow.Gateway",
    "Audience": "Ocow.Microservices",
    "Secret": "PleaseChangeThisGatewayForwardedJwtSecret",
    "TokenExpireMinutes": 5,
    "GatewayName": "Ocow.Gateway"
  },
  "InternalAuth": {
    "Issuer": "Ocow.InternalAuth",
    "Audience": "Ocow.InternalServices",
    "Secret": "PleaseChangeThisInternalServiceJwtSecret",
    "ServiceName": "Ocow.Jobs",
    "TokenExpireMinutes": 10
  },
  "HmacSignature": {
    "Secret": "PleaseChangeThisInternalHmacSecret",
    "TimestampToleranceSeconds": 300
  },
  "AllowedHosts": "*"
}
