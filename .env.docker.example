# 复制为 .env 后，docker compose 会自动读取这些变量。

# 对外访问端口
OCOW_ADMIN_WEB_PORT=8088
OCOW_GATEWAY_PORT=5000
OCOW_POSTGRES_PORT=15432
OCOW_REDIS_PORT=16379
OCOW_RABBITMQ_PORT=15670
OCOW_RABBITMQ_MANAGEMENT_PORT=15672

# PostgreSQL
OCOW_POSTGRES_USER=postgres
OCOW_POSTGRES_PASSWORD=postgres123
OCOW_POSTGRES_DB=postgres
OCOW_IDENTITY_DB_NAME=ocow_identity
OCOW_ORDER_DB_NAME=ocow_order
OCOW_JOBS_DB_NAME=ocow_jobs
OCOW_FILE_DB_NAME=ocow_file

# 文件存储：Local 或 TencentCos/Cos
OCOW_FILE_STORAGE_TYPE=Local
OCOW_FILE_COS_BUCKET_NAME=
OCOW_FILE_COS_REGION=ap-guangzhou
OCOW_FILE_COS_SECRET_ID=
OCOW_FILE_COS_SECRET_KEY=
OCOW_FILE_COS_KEY_PREFIX=uploads

# RabbitMQ
OCOW_RABBITMQ_USER=admin
OCOW_RABBITMQ_PASSWORD=admin123

# 初始后台管理员账号
OCOW_IDENTITY_ADMIN_USERNAME=admin
OCOW_IDENTITY_ADMIN_PASSWORD=Admin@123456
OCOW_IDENTITY_ADMIN_DISPLAY_NAME=系统管理员

# JWT 与内部调用密钥；生产环境必须替换为高强度随机值。
OCOW_JWT_SECRET=OcowIdentityJwtSecret@2026-ChangeInProduction
OCOW_JWT_ISSUER=Ocow.Identity
OCOW_JWT_AUDIENCE=Ocow.Clients
OCOW_GATEWAY_FORWARDED_JWT_SECRET=PleaseChangeThisGatewayForwardedJwtSecret
OCOW_GATEWAY_FORWARDED_JWT_ISSUER=Ocow.Gateway
OCOW_GATEWAY_FORWARDED_JWT_AUDIENCE=Ocow.InternalServices
OCOW_INTERNAL_AUTH_SECRET=PleaseChangeThisInternalServiceJwtSecret
OCOW_HMAC_SIGNATURE_SECRET=PleaseChangeThisInternalHmacSecret

# 只在前端容器需要访问宿主机网关时取消注释。
# GATEWAY_BASE_URL=http://host.docker.internal:5000
